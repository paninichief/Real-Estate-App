# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Supabase project settings (Project Settings -> API in the Supabase dashboard).
# NEXT_PUBLIC_* vars are safe to expose to the browser: the anon key is
# restricted by Row Level Security, not a secret credential.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of this app, used to build the Google OAuth redirect target.
# Local dev: http://localhost:3000
# Vercel preview/production: the deployed URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
